    "name = input(\"Please state your name: \")\n",
    "age = 0\n",
    "while True:\n",
    "    try:\n",
    "        age = int(input(\"Please enter your age: \"))\n",
    "        break\n",
    "    except:\n",
    "        continue\n",
    "print(\"Name: \" + name + \"\\n\" + \"Age: \" + str(age))"
   ]
